{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LogiNext",
  "version": "0.1.0",
  "identifier": "dev.loginext.ui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LogiNext",
        "width": 1080,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "backgroundColor": "#1e1f24"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "LogiNext — Logitech device control panel",
    "longDescription": "Configure MX Master 3S bindings and sensitivity through the LogiNext daemon.",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
